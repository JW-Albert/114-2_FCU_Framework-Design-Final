# Apache Maven Wrapper startup shell script

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=`which java`
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

if [ ! -x "$JAVACMD" ] ; then
  echo "Error: JAVA_HOME is not defined correctly." >&2
  echo "  We cannot execute $JAVACMD" >&2
  exit 1
fi

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-}"
findBaseDir() {
    if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
        MAVEN_PROJECTBASEDIR=$(pwd)
        while [ ! -d "$MAVEN_PROJECTBASEDIR/.mvn" ]; do
            PARENT=$(dirname "$MAVEN_PROJECTBASEDIR")
            if [ "$PARENT" = "$MAVEN_PROJECTBASEDIR" ]; then
                break
            fi
            MAVEN_PROJECTBASEDIR="$PARENT"
        done
    fi
}
findBaseDir

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"
DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"

if [ ! -e "$WRAPPER_JAR" ]; then
    if command -v curl > /dev/null; then
        curl -o "$WRAPPER_JAR" "$DOWNLOAD_URL" -f
    elif command -v wget > /dev/null; then
        wget "$DOWNLOAD_URL" -O "$WRAPPER_JAR"
    else
        echo "Error: Could not download maven wrapper. Please install curl or wget." >&2
        exit 1
    fi
fi

exec "$JAVACMD" \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  $MAVEN_OPTS \
  "$WRAPPER_LAUNCHER" "$MAVEN_CONFIG" "$@"
